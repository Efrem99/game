    "rules": [
        {
            "name": "life_death_override",
            "from": [
                "*"
            ],
            "to": "dead",
            "condition": "hp <= 0",
            "priority": 0,
            "force": true
        },
        {
            "name": "hard_landing_event",
            "from": [
                "*"
            ],
            "to": "falling_hard",
            "trigger": "hard_landing",
            "priority": 10,
            "force": true
        },
        {
            "name": "mount_context_move",
            "from": [
                "*"
            ],
            "to": "mounted_move",
            "condition": "mounted && speed > 0.15",
            "priority": 14
        },
        {
            "name": "mount_context_idle",
            "from": [
                "*"
            ],
            "to": "mounted_idle",
            "condition": "mounted && speed <= 0.15",
            "priority": 14
        },
        {
            "name": "flight_context",
            "from": [
                "*"
            ],
            "to": "flying",
            "condition": "is_flying && !mounted",
            "priority": 22
        },
        {
            "name": "water_context",
            "from": [
                "*"
            ],
            "to": "swim",
            "condition": "in_water && !mounted && !is_flying",
            "priority": 24
        },
        {
            "name": "wallrun_exit_unstable",
            "from": [
                "wallrun"
            ],
            "to": "staggered",
            "trigger": "exit_wallrun",
            "condition": "!on_ground && speed > 7.0",
            "priority": 25
        },
        {
            "name": "falling_reacquire",
            "from": [
                "*"
            ],
            "to": "falling",
            "condition": "!on_ground && vertical_speed < -0.35 && !is_flying && !mounted && !in_water",
            "priority": 34
        }
    ],
