{
    "_comment": "Dialogue System JSON Schema - Documentation",
    "_description": "This file describes the structure for NPC dialogue trees",
    "schema_version": "1.0",
    "example_structure": {
        "npc_id": "unique_npc_identifier",
        "npc_name": "NPC Display Name",
        "portrait": "optional_path_to_portrait_image",
        "dialogue_tree": {
            "start": {
                "speaker": "NPC Name",
                "text": "The dialogue text that the NPC says",
                "animation": "npc_animation_to_play (greet, idle, celebrate, etc.)",
                "choices": [
                    {
                        "text": "Player choice text",
                        "next_node": "node_id_to_jump_to",
                        "condition": "optional: quest_active:tutorial_quest",
                        "action": "optional: give_quest:tutorial_quest"
                    }
                ]
            },
            "node_id": {
                "speaker": "NPC Name",
                "text": "More dialogue text",
                "animation": "idle",
                "choices": [
                    {
                        "text": "Choice 1",
                        "next_node": "another_node"
                    },
                    {
                        "text": "Goodbye",
                        "next_node": "end",
                        "action": "end_dialogue"
                    }
                ]
            },
            "end": {
                "speaker": "NPC Name",
                "text": "Farewell message",
                "animation": "idle",
                "choices": []
            }
        }
    },
    "condition_types": {
        "quest_active": "Check if quest is active (quest_active:quest_id)",
        "quest_complete": "Check if quest is complete (quest_complete:quest_id)",
        "has_item": "Check if player has item (has_item:item_id)",
        "gold_amount": "Check player gold (gold_amount:>=100)",
        "level": "Check player level (level:>=5)",
        "can_recruit": "Check if a pet or companion can currently be recruited (can_recruit:member_id or can_recruit:member_id:hire)",
        "has_companion": "Check if a specific companion is already owned (has_companion:member_id)",
        "has_pet": "Check if a specific pet is already owned (has_pet:member_id)",
        "active_companion": "Check the currently active companion (active_companion:member_id)",
        "active_pet": "Check the currently active pet (active_pet:member_id)"
    },
    "action_types": {
        "give_quest": "Start a quest (give_quest:quest_id)",
        "complete_quest": "Complete a quest (complete_quest:quest_id)",
        "open_shop": "Open merchant shop (open_shop)",
        "give_item": "Give item to player (give_item:item_id:count)",
        "give_gold": "Give gold to player (give_gold:amount)",
        "hire_companion": "Hire a dialogue-gated companion (hire_companion:member_id)",
        "rescue_companion": "Recruit a companion by rescue outcome (rescue_companion:member_id)",
        "story_companion": "Recruit a companion from a story beat (story_companion:member_id)",
        "grant_story_companion": "Alias for story-based companion recruitment (grant_story_companion:member_id)",
        "tame_pet": "Recruit a pet through a taming encounter (tame_pet:member_id)",
        "activate_companion": "Set an owned companion as active (activate_companion:member_id)",
        "activate_pet": "Set an owned pet as active (activate_pet:member_id)",
        "dismiss_companion": "Clear the active companion slot",
        "dismiss_pet": "Clear the active pet slot",
        "end_dialogue": "End the dialogue conversation"
    }
}
